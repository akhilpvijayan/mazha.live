# ─── Supabase ────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── VAPID (Web Push) ─────────────────────────────────────────
# Generate at: https://vapidkeys.com
# OR run: npx web-push generate-vapid-keys
# The PUBLIC key goes here (client side, safe to expose)
# The PRIVATE key goes in Supabase Edge Function secrets ONLY
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
